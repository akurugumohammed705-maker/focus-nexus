# Copy this file to .env and fill in your Supabase project values.
# Find these in Supabase: Project Settings → API.
# The anon key is safe for the browser — it's public by design and
# access is enforced by Row-Level Security policies, not by keeping it secret.
# Never put your service_role key or any payment/supplier secret keys here —
# those belong only inside Supabase Edge Functions.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
